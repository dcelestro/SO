generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  idea
  active
  paused
  blocked
  completed
  discarded
  frozen
}

enum Priority {
  critical
  high
  medium
  low
}

enum ProjectMaturity {
  idea
  validation
  design
  development
  testing
  production
  maintenance
}

enum ProjectType {
  app
  web
  ecommerce
  newsletter
  infrastructure
  admin
  content
  business
  other
}

enum Level {
  high
  medium
  low
}

enum TaskStatus {
  inbox
  pending
  in_progress
  waiting
  blocked
  completed
  discarded
}

enum TaskContext {
  development
  design
  research
  admin
  commercial
  content
  review
  purchase
  call
  other
}

enum AssetType {
  domain
  hosting
  database
  email
  api
  repository
  cloud_service
  payment_gateway
  social_media
  design_file
  analytics
  backup
  server
  legal_tax
  other
}

enum AssetStatus {
  active
  inactive
  pending
  expired
  cancelled
}

enum IdeaStatus {
  captured
  evaluating
  future
  converted_to_project
  discarded
}

enum DueItemType {
  domain
  hosting
  subscription
  license
  api
  payment
  backup
  ssl
  tax
  review
  other
}

enum DueItemStatus {
  pending
  done
  overdue
  cancelled
}

enum RecurrenceType {
  none
  weekly
  monthly
  quarterly
  yearly
  custom
}

enum ReviewType {
  weekly_review
  monthly_review
  project_review
  backup_review
  financial_review
  content_review
  system_review
  other
}

enum Frequency {
  weekly
  monthly
  quarterly
  yearly
  custom
}

enum ReviewStatus {
  pending
  done
  overdue
  cancelled
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Area {
  id          String         @id @default(cuid())
  name        String         @unique
  description String?
  color       String?
  projects    Project[]
  tasks       Task[]
  assets      DigitalAsset[]
  ideas       Idea[]
  reviews     Review[]
  notes       Note[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Project {
  id                  String                        @id @default(cuid())
  name                String
  description         String?
  areaId              String
  area                Area                          @relation(fields: [areaId], references: [id], onDelete: Restrict)
  status              ProjectStatus                 @default(idea)
  priority            Priority                      @default(medium)
  maturity            ProjectMaturity               @default(idea)
  projectType         ProjectType                   @default(other)
  impactLevel         Level?
  effortLevel         Level?
  technicalComplexity Level?
  currentEnergy       Level?
  startDate           DateTime?
  targetDate          DateTime?
  reviewDate          DateTime?
  nextAction          String?
  blockedReason       String?
  progressPercentage  Int                           @default(0)
  isFrozen            Boolean                       @default(false)
  frozenReason        String?
  frozenUntil         DateTime?
  tasks               Task[]
  assets              DigitalAsset[]
  ideas               Idea[]
  dueItems            DueItem[]
  reviews             Review[]
  notes               Note[]
  weeklyMain          WeeklyFocus[]                 @relation("MainFocus")
  secondaryIn         WeeklyFocusSecondaryProject[]
  avoidedIn           WeeklyFocusAvoidProject[]
  createdAt           DateTime                      @default(now())
  updatedAt           DateTime                      @updatedAt

  @@index([status, priority])
  @@index([areaId])
}

model Task {
  id               String       @id @default(cuid())
  title            String
  description      String?
  projectId        String?
  project          Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  areaId           String?
  area             Area?        @relation(fields: [areaId], references: [id], onDelete: SetNull)
  status           TaskStatus   @default(inbox)
  priority         Priority     @default(medium)
  dueDate          DateTime?
  startDate        DateTime?
  estimatedMinutes Int?
  energyLevel      Level?
  context          TaskContext?
  isToday          Boolean      @default(false)
  isCritical       Boolean      @default(false)
  completedAt      DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([status, dueDate])
  @@index([projectId])
}

model DigitalAsset {
  id                       String      @id @default(cuid())
  name                     String
  projectId                String?
  project                  Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  areaId                   String?
  area                     Area?       @relation(fields: [areaId], references: [id], onDelete: SetNull)
  type                     AssetType
  provider                 String?
  url                      String?
  accountEmail             String?
  username                 String?
  passwordManagerReference String?
  notes                    String?
  renewalDate              DateTime?
  cost                     Decimal?    @db.Decimal(12, 2)
  currency                 String?
  status                   AssetStatus @default(active)
  dueItems                 DueItem[]
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  @@index([renewalDate, status])
}

model Idea {
  id          String     @id @default(cuid())
  title       String
  description String?
  areaId      String?
  area        Area?      @relation(fields: [areaId], references: [id], onDelete: SetNull)
  projectId   String?
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  potential   Level?
  complexity  Level?
  status      IdeaStatus @default(captured)
  reviewDate  DateTime?
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model DueItem {
  id           String         @id @default(cuid())
  title        String
  description  String?
  projectId    String?
  project      Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  assetId      String?
  asset        DigitalAsset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)
  type         DueItemType
  dueDate      DateTime
  reminderDate DateTime?
  recurrence   RecurrenceType @default(none)
  status       DueItemStatus  @default(pending)
  amount       Decimal?       @db.Decimal(12, 2)
  currency     String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([dueDate, status])
}

model Review {
  id             String       @id @default(cuid())
  title          String
  description    String?
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  areaId         String?
  area           Area?        @relation(fields: [areaId], references: [id], onDelete: SetNull)
  type           ReviewType
  frequency      Frequency
  nextReviewDate DateTime
  lastReviewDate DateTime?
  status         ReviewStatus @default(pending)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([nextReviewDate, status])
}

model WeeklyFocus {
  id                String                        @id @default(cuid())
  weekStartDate     DateTime
  weekEndDate       DateTime
  mainProjectId     String?
  mainProject       Project?                      @relation("MainFocus", fields: [mainProjectId], references: [id], onDelete: SetNull)
  weeklyGoal        String?
  notes             String?
  secondaryProjects WeeklyFocusSecondaryProject[]
  avoidProjects     WeeklyFocusAvoidProject[]
  createdAt         DateTime                      @default(now())
  updatedAt         DateTime                      @updatedAt

  @@index([weekStartDate, weekEndDate])
}

model WeeklyFocusSecondaryProject {
  id            String      @id @default(cuid())
  weeklyFocusId String
  weeklyFocus   WeeklyFocus @relation(fields: [weeklyFocusId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([weeklyFocusId, projectId])
}

model WeeklyFocusAvoidProject {
  id            String      @id @default(cuid())
  weeklyFocusId String
  weeklyFocus   WeeklyFocus @relation(fields: [weeklyFocusId], references: [id], onDelete: Cascade)
  projectId     String
  project       Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([weeklyFocusId, projectId])
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  areaId    String?
  area      Area?    @relation(fields: [areaId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  action      String
  description String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([createdAt])
}
