generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AreaStatus {
  active
  paused
  archived
}
enum ProjectStatus {
  idea
  analysis
  active
  paused
  blocked
  frozen
  completed
  discarded
}
enum ModuleStatus {
  planned
  active
  paused
  blocked
  completed
  discarded
}
enum Priority {
  critical
  high
  medium
  low
}
enum Level {
  high
  medium
  low
}
enum ProjectType {
  app
  web
  ecommerce
  newsletter
  infrastructure
  admin
  content
  business
  other
}
enum ProjectMaturity {
  idea
  validation
  design
  development
  testing
  production
  maintenance
}
enum ModuleType {
  feature
  backend
  frontend
  database
  design
  content
  infrastructure
  legal_admin
  commercial
  documentation
  other
}
enum TaskStatus {
  inbox
  pending
  in_progress
  waiting
  blocked
  completed
  discarded
}
enum TaskContext {
  development
  design
  research
  admin
  commercial
  content
  review
  purchase
  call
  other
}
enum DocumentType {
  specification
  brief
  design
  contract
  note
  research
  technical
  commercial
  legal
  other
}
enum ResourceType {
  domain
  hosting
  database
  repository
  api
  design_file
  provider
  tool
  account
  cloud_service
  payment_gateway
  analytics
  backup
  server
  other
}
enum ResourceStatus {
  active
  inactive
  pending
  expired
  cancelled
}
enum DecisionStatus {
  active
  revised
  discarded
}
enum ImportantDateType {
  deadline
  milestone
  launch
  review
  renewal
  payment
  meeting
  delivery
  other
}
enum DateStatus {
  pending
  done
  overdue
  cancelled
}
enum AlertType {
  overdue_task
  missing_next_action
  upcoming_date
  blocked_project
  blocked_module
  inactive_project
  inactive_module
  too_many_active_projects
  manual
  other
}
enum AlertSeverity {
  low
  medium
  high
  critical
}
enum AlertStatus {
  active
  resolved
  dismissed
}
enum InboxItemType {
  capture
  task
  document
  credential
  resource
  decision
  important_date
  alert
  project
  module
}
enum InboxStatus {
  pending
  processed
  discarded
}
enum FocusScopeType {
  area
  project
  module
}
enum ShortcutType {
  system
  area
  project
  module
  resource
  inbox
  alerts
  custom
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Area {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  color       String?
  status      AreaStatus @default(active)
  projects    Project[]
  modules     ProjectModule[]
  tasks       Task[]
  documents   Document[]
  credentials Credential[]
  resources   Resource[]
  decisions   Decision[]
  dates       ImportantDate[]
  alerts      Alert[]
  activities  ActivityLog[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Project {
  id                 String          @id @default(cuid())
  name               String
  description        String?
  areaId             String
  area               Area            @relation(fields: [areaId], references: [id], onDelete: Cascade)
  status             ProjectStatus   @default(idea)
  priority           Priority        @default(medium)
  projectType        ProjectType     @default(other)
  maturity           ProjectMaturity @default(idea)
  nextAction         String?
  blockedReason      String?
  progressPercentage Int             @default(0)
  startDate          DateTime?
  targetDate         DateTime?
  reviewDate         DateTime?
  isFrozen           Boolean         @default(false)
  frozenReason       String?
  frozenUntil        DateTime?
  modules            ProjectModule[]
  tasks              Task[]
  documents          Document[]
  credentials        Credential[]
  resources          Resource[]
  decisions          Decision[]
  dates              ImportantDate[]
  alerts             Alert[]
  activities         ActivityLog[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([areaId, status])
}

model ProjectModule {
  id                 String       @id @default(cuid())
  name               String
  description        String?
  areaId             String
  area               Area         @relation(fields: [areaId], references: [id], onDelete: Cascade)
  projectId          String
  project            Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status             ModuleStatus @default(planned)
  priority           Priority     @default(medium)
  moduleType         ModuleType   @default(other)
  nextAction         String?
  blockedReason      String?
  progressPercentage Int          @default(0)
  targetDate         DateTime?
  reviewDate         DateTime?
  tasks              Task[]
  documents          Document[]
  credentials        Credential[]
  resources          Resource[]
  decisions          Decision[]
  dates              ImportantDate[]
  alerts             Alert[]
  activities         ActivityLog[]
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@unique([projectId, name])
  @@index([areaId, projectId, status])
}

model Task {
  id               String        @id @default(cuid())
  title            String
  description      String?
  areaId           String
  area             Area          @relation(fields: [areaId], references: [id], onDelete: Cascade)
  projectId        String?
  project          Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId         String?
  module           ProjectModule? @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  status           TaskStatus    @default(pending)
  priority         Priority      @default(medium)
  dueDate          DateTime?
  startDate        DateTime?
  estimatedMinutes Int?
  energyLevel      Level?
  context          TaskContext?
  completedAt      DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([areaId, projectId, moduleId])
  @@index([status, dueDate])
}

model Document {
  id          String        @id @default(cuid())
  title       String
  description String?
  areaId      String
  area        Area          @relation(fields: [areaId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId    String?
  module      ProjectModule? @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  type        DocumentType  @default(other)
  url         String?
  filePath    String?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([areaId, projectId, moduleId])
}

model Credential {
  id                       String         @id @default(cuid())
  name                     String
  areaId                   String
  area                     Area           @relation(fields: [areaId], references: [id], onDelete: Cascade)
  projectId                String?
  project                  Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId                 String?
  module                   ProjectModule? @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  serviceName              String?
  url                      String?
  username                 String?
  email                    String?
  passwordManagerReference String?
  notes                    String?
  has2FA                   Boolean        @default(false)
  recoveryEmail            String?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  @@index([areaId, projectId, moduleId])
}

model Resource {
  id          String         @id @default(cuid())
  name        String
  areaId      String
  area        Area           @relation(fields: [areaId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId    String?
  module      ProjectModule? @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  type        ResourceType   @default(other)
  provider    String?
  url         String?
  notes       String?
  renewalDate DateTime?
  status      ResourceStatus @default(active)
  credentialProvider     String?
  credentialReference    String?
  credentialLabel        String?
  credentialUsernameHint String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([areaId, projectId, moduleId])
}

model Decision {
  id           String         @id @default(cuid())
  title        String
  description  String?
  areaId       String
  area         Area           @relation(fields: [areaId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId     String?
  module       ProjectModule? @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  reason       String?
  consequences String?
  status       DecisionStatus @default(active)
  decidedAt    DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([areaId, projectId, moduleId])
}

model ImportantDate {
  id           String            @id @default(cuid())
  title        String
  description  String?
  areaId       String
  area         Area              @relation(fields: [areaId], references: [id], onDelete: Cascade)
  projectId    String?
  project      Project?          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId     String?
  module       ProjectModule?    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  type         ImportantDateType @default(other)
  date         DateTime
  reminderDate DateTime?
  status       DateStatus        @default(pending)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([areaId, projectId, moduleId])
  @@index([status, date])
}

model Alert {
  id          String         @id @default(cuid())
  title       String
  description String?
  areaId      String
  area        Area           @relation(fields: [areaId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId    String?
  module      ProjectModule? @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  type        AlertType      @default(manual)
  severity    AlertSeverity  @default(medium)
  status      AlertStatus    @default(active)
  source      String?
  createdAt   DateTime       @default(now())
  resolvedAt  DateTime?

  @@index([areaId, projectId, moduleId])
  @@index([status, severity])
}

model InboxItem {
  id          String        @id @default(cuid())
  title       String
  description String?
  type        InboxItemType @default(capture)
  status      InboxStatus   @default(pending)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model WeeklyFocus {
  id                 String         @id @default(cuid())
  weekStartDate      DateTime
  weekEndDate        DateTime
  mainScopeType      FocusScopeType
  mainAreaId         String?
  mainProjectId      String?
  mainModuleId       String?
  secondaryScopes    Json           @default("[]")
  avoidScopes        Json           @default("[]")
  weeklyGoal         String?
  notes              String?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([weekStartDate, weekEndDate])
}

model ActivityLog {
  id          String         @id @default(cuid())
  areaId      String?
  area        Area?          @relation(fields: [areaId], references: [id], onDelete: Cascade)
  projectId   String?
  project     Project?       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  moduleId    String?
  module      ProjectModule? @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  entityType  String
  entityId    String
  action      String
  description String?
  createdAt   DateTime       @default(now())

  @@index([areaId, projectId, moduleId])
  @@index([createdAt])
}

model DesktopShortcut {
  id           String        @id @default(cuid())
  name         String
  description  String?
  type         ShortcutType  @default(custom)
  icon         String?
  color        String?
  targetType   String?
  targetId     String?
  sortOrder    Int           @default(0)
  isPinned     Boolean       @default(false)
  lastOpenedAt DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([sortOrder, isPinned])
}
