# Required by Prisma and the API when running against the local Docker database.
# Matches docker-compose.yml.
DATABASE_URL="postgresql://nexo:nexo@localhost:5434/nexo?schema=public"

# Optional for local development.
# Keep false to validate the app without the login flow.
# Set to true to require the seeded user credentials.
AUTH_ENABLED="false"

# Optional locally while AUTH_ENABLED=false.
# Replace before enabling auth in any shared or production-like environment.
AUTH_SECRET="replace-with-a-long-random-secret-before-enabling-auth"
